{
  "name": "lorflux-platform",
  "version": "2.3.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "server": "node server.js",
    "worker": "node workers/videoWorker.js",
    "start": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop ecosystem.config.js",
    "restart": "pm2 restart ecosystem.config.js",
    "build": "vite build",
    "preview": "vite preview",
    "backup": "bash scripts/backup.sh",
    "validate:env": "node scripts/validateEnv.js",
    "seed:admin": "node scripts/seedAdmin.js",
    "build:frontend": "npm run build && mkdir -p frontend-dist && cp -r dist/* frontend-dist/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:backend": "node --experimental-vm-modules node_modules/.bin/jest tests/api.content.test.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1003.0",
    "@google/genai": "^1.41.0",
    "@sentry/node": "^8.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.0.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "googleapis": "^144.0.0",
    "helmet": "^7.1.0",
    "hls.js": "^1.5.7",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.564.0",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.33.2",
    "stripe": "^14.0.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.17",
    "jsdom": "^29.0.0",
    "postcss": "^8.4.35",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.0"
  }
}