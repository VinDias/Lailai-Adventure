
PORT=3000
NODE_ENV=production
# Segredos: use >= 32 caracteres aleatórios e ÚNICOS (diferentes entre si).
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-por-48-bytes-hex-aleatorios
REFRESH_SECRET=troque-por-OUTRO-48-bytes-hex-aleatorios
MEDIA_TOKEN_SECRET=troque-por-mais-um-48-bytes-hex-aleatorios
FRONTEND_URL=https://www.lorflux.com
MEDIA_BASE_URL=https://cdn.loreflux.com
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
# Multi-currency Price IDs (criar no Stripe Dashboard — cada moeda precisa de um Price separado para subscription)
STRIPE_PRICE_ID_BRL=price_...
STRIPE_PRICE_ID_USD=price_...
STRIPE_PRICE_ID_EUR=price_...
REDIS_URL=redis://127.0.0.1:6379
SENTRY_DSN=https://...
S3_ENDPOINT=https://...
S3_ACCESS_KEY=...
S3_SECRET_KEY=...
S3_BUCKET_NAME=loreflux-production

# BUNNY.NET STREAM
BUNNY_API_KEY=sua-api-key
BUNNY_LIBRARY_ID=seu-library-id
BUNNY_CDN_HOSTNAME=vz-xxxxx-xxx.b-cdn.net
# Token Authentication (ative em Stream > Library > Security > Token Authentication)
BUNNY_TOKEN_KEY=sua-token-key-da-biblioteca
# OBRIGATÓRIO p/ webhook: configure a URL no painel Bunny como
#   https://SEU_DOMINIO/api/bunny/webhook?token=ESTE_VALOR
BUNNY_WEBHOOK_SECRET=segredo-forte-do-webhook

# BUNNY.NET STORAGE (imagens de painéis e áudio)
BUNNY_STORAGE_ZONE=lorflux
BUNNY_STORAGE_KEY=sua-storage-api-key
BUNNY_STORAGE_HOSTNAME=lorflux.b-cdn.net

# E-MAIL TRANSACIONAL (Hostinger Business Email / SMTP)
# Configurar DNS no Cloudflare antes de usar — ver EMAIL_SETUP.md
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@lorflux.com
SMTP_PASS=senha-do-email
FROM_EMAIL=noreply@lorflux.com
FROM_NAME=Lorflux

# PAGAMENTO MOBILE (opcional — apps Android/iOS)
ANDROID_PACKAGE_NAME=com.lorflux.app
APPLE_SHARED_SECRET=seu-shared-secret-apple

# SEED DO PRIMEIRO SUPERADMIN (usado por: npm run seed:admin)
SEED_ADMIN_EMAIL=admin@lorflux.com
SEED_ADMIN_PASSWORD=defina-uma-senha-forte-aqui
SEED_ADMIN_NAME=Administrador

# ESCALABILIDADE & LIMITES
WORKER_CONCURRENCY=2
MAX_ADMIN_COUNT=10
MAX_UPLOAD_SIZE=500mb
