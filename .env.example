FRONTEND_URL=https://www.loreflux.com
MEDIA_BASE_URL=https://cdn.loreflux.com
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
REDIS_URL=redis://127.0.0.1:6379
SENTRY_DSN=https://...
